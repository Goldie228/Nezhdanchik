<div class="min-h-screen bg-base-200">
  <!-- Навигация -->
  <div class="navbar bg-base-100 shadow-lg">
    <div class="flex-1">
      <a class="btn btn-ghost normal-case text-xl">Панель менеджера</a>
    </div>
    <div class="flex-none">
      <ul class="menu menu-horizontal p-0">
        <li><%= link_to "Обзор", manager_dashboard_path %></li>
        <li><%= link_to "Календарь", manager_calendar_path, class: "active" %></li>
        <li><%= link_to "Столы", manager_tables_path %></li>
        <li><%= link_to "Бронирования", manager_bookings_path %></li>
      </ul>
    </div>
  </div>

  <div class="container mx-auto px-4 py-6">
    <!-- Заголовок и навигация по датам -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
      <div>
        <h1 class="text-3xl font-bold">Календарь бронирований</h1>
        <p class="text-base-content/70">Просмотр и управление бронированиями</p>
      </div>
      <div class="flex gap-2 items-center">
        <%= link_to manager_calendar_path(date: @selected_date - 1.day), class: "btn btn-outline" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        <% end %>
        
        <div class="form-control">
          <input type="date" id="date-picker" class="input input-bordered" value="<%= @selected_date.strftime('%Y-%m-%d') %>">
        </div>
        
        <%= link_to manager_calendar_path(date: @selected_date + 1.day), class: "btn btn-outline" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        <% end %>
        
        <%= link_to "Сегодня", manager_calendar_path, class: "btn btn-primary" %>
      </div>
    </div>

    <!-- Календарь с временными слотами -->
    <div class="bg-base-100 rounded-lg shadow-lg p-6 mb-6">
      <h2 class="text-xl font-bold mb-4">Бронирования на <%= @selected_date.strftime('%d %B %Y') %></h2>
      
      <!-- Легенда -->
      <div class="flex flex-wrap gap-4 mb-4">
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 bg-success rounded"></div>
          <span class="text-sm">Свободно</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 bg-warning rounded"></div>
          <span class="text-sm">Ожидает подтверждения</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 bg-info rounded"></div>
          <span class="text-sm">Подтверждено</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 bg-neutral rounded"></div>
          <span class="text-sm">Недоступно</span>
        </div>
      </div>
      
      <!-- Таблица с временными слотами -->
      <div class="overflow-x-auto">
        <table class="table table-compact w-full">
          <thead>
            <tr>
              <th>Время</th>
              <% @tables.each do |table| %>
                <th class="text-center">Стол <%= table.name %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% # Генерируем временные слоты с шагом в 30 минут %>
            <% (9..23).each do |hour| %>
              <% [0, 30].each do |minute| %>
                <% time_slot = Time.zone.parse("#{@selected_date.strftime('%Y-%m-%d')} #{hour.to_s.rjust(2, '0')}:#{minute.to_s.rjust(2, '0')}:00") %>
                <tr>
                  <td class="font-semibold">
                    <%= time_slot.strftime('%H:%M') %>
                  </td>
                  <% @tables.each do |table| %>
                    <% booking = @bookings.find { |b| b.seats.any? { |s| s.table_id == table.id } && b.starts_at <= time_slot && b.ends_at > time_slot } %>
                    <td class="text-center p-1">
                      <% if booking %>
                        <%= link_to manager_booking_path(booking), class: "block w-full h-full p-1 rounded" do %>
                          <div class="tooltip" data-tip="<%= booking.user&.full_name %><br>Бронь №#{booking.booking_number}<br>до #{booking.ends_at.strftime('%H:%M')}">
                            <div class="w-full h-full <%= 
                              booking.status == 'pending' ? 'bg-warning' : 
                              booking.status == 'confirmed' ? 'bg-info' : 
                              'bg-neutral' 
                            %> rounded text-xs text-white p-1">
                              <%= booking.user&.full_name&.split&.first %>
                            </div>
                          </div>
                        <% end %>
                      <% else %>
                        <div class="w-full h-full bg-success rounded"></div>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Список бронирований на выбранный день -->
    <div class="bg-base-100 rounded-lg shadow-lg p-6">
      <h2 class="text-xl font-bold mb-4">Бронирования на <%= @selected_date.strftime('%d %B %Y') %></h2>
      <div class="overflow-x-auto">
        <table class="table table-compact w-full">
          <thead>
            <tr>
              <th>Номер</th>
              <th>Клиент</th>
              <th>Стол</th>
              <th>Время</th>
              <th>Статус</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody>
            <% @bookings.each do |booking| %>
              <tr>
                <td><%= booking.booking_number %></td>
                <td><%= booking.user&.full_name || "Неизвестный" %></td>
                <td>
                  <% if booking.seats.any? %>
                    <% seats_by_table = booking.seats.group_by(&:table_id) %>
                    <% seats_by_table.each do |table_id, seats| %>
                      <% if table_id.present? %>
                        <span class="badge badge-outline">Стол <%= seats.first.table.name %></span>
                      <% else %>
                        <% seats.each do |seat| %>
                          <span class="badge badge-outline">М<%= seat.number %></span>
                        <% end %>
                      <% end %>
                    <% end %>
                  <% else %>
                    <span class="badge badge-outline">Нет данных</span>
                  <% end %>
                </td>
                <td>
                  <%= booking.starts_at.strftime('%H:%M') %> - <%= booking.ends_at.strftime('%H:%M') %>
                </td>
                <td>
                  <div class="badge <%= 
                    booking.status == 'pending' ? 'badge-warning' : 
                    booking.status == 'confirmed' ? 'badge-info' : 
                    'badge-success' 
                  %>">
                    <%= booking.status %>
                  </div>
                </td>
                <td>
                  <%= link_to "Детали", manager_booking_path(booking), class: "btn btn-ghost btn-xs" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const datePicker = document.getElementById('date-picker');
    
    datePicker.addEventListener('change', function() {
      const selectedDate = this.value;
      window.location.href = `/manager/calendar?date=${selectedDate}`;
    });
  });
</script>
